# PostgreSQL
POSTGRES_USER=editorial
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=editorial_db
DATABASE_URL=postgresql://editorial:change_me_in_production@postgres:5432/editorial_db

# Backend
NODE_ENV=production
PORT=3000
JWT_SECRET=change_this_to_a_random_64_char_string
CORS_ORIGIN=http://localhost

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# n8n
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook
N8N_API_KEY=optional-n8n-api-key

# n8n service config
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost/n8n/

# Admin seed
ADMIN_EMAIL=admin@editorial.local
ADMIN_PASSWORD=change_me_in_production
